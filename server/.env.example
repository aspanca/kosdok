# Server
PORT=4000
NODE_ENV=development

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kosdok
# SSL (required for DigitalOcean managed DB)
DB_SSL_CA_PATH=./src/certs/ca-certificate (2).crt

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (format: cloudinary://api_key:api_secret@cloud_name)
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Admin Dashboard URL (for CORS)
ADMIN_URL=http://localhost:5174

# SMTP (for verification emails)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kosdok.com
