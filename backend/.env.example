PORT=8080
ENV=development
DB_PATH=./data/app.db
JWT_SECRET=dev-change-me
JWT_ISSUER=kosdok-api
JWT_AUDIENCE=kosdok-clients
JWT_LEEWAY_SECONDS=5
TRUSTED_ORIGINS=
AUTH_LOGIN_RATE_LIMIT_PER_MIN=10
AUTH_REGISTER_RATE_LIMIT_PER_MIN=5

# SQLite tuning
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_FOREIGN_KEYS=true
REFRESH_TOKEN_REVOKED_RETENTION_DAYS=30
