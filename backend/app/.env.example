# Copy this file to .env.development for local development.
# In production, create .env.production with real secrets.

NODE_ENV=development
PORT=3000
APP_PUBLIC_URL=http://localhost:3000

JWT_ACCESS_SECRET=change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=kosdok
DB_PASSWORD=kosdok
DB_NAME=kosdok

# Mail mode:
# - console: logs only, no delivery
# - smtp: sends through SMTP (use Mailpit in dev)
MAIL_TRANSPORT=smtp
MAIL_FROM=no-reply@kosdok.local
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_SECURE=false
